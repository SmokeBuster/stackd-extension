generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  googleId       String          @unique
  email          String          @unique
  name           String
  avatar         String?
  university     String?
  coinBalance    Int             @default(0)
  createdAt      DateTime        @default(now())
  codes          ReferralCode[]
  redemptions    Redemption[]
  codeVotes      CodeVote[]
  benefitUpvotes BenefitUpvote[]
}

model ReferralCode {
  id          String     @id @default(cuid())
  brand       String
  domain      String
  emoji       String     @default("🏷")
  code        String
  description String
  category    String
  coins       Int        @default(50)
  expiresIn   String     @default("30 days")
  yesVotes    Int        @default(0)
  noVotes     Int        @default(0)
  successRate Float      @default(0)
  dealDna     String?
  isExpired   Boolean    @default(false)
  source      String?
  createdAt   DateTime   @default(now())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  codeVotes   CodeVote[]
}

model CodeVote {
  id        String       @id @default(cuid())
  codeId    String
  userId    String
  vote      String
  createdAt DateTime     @default(now())
  code      ReferralCode @relation(fields: [codeId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@unique([codeId, userId])
}

model Redemption {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  giftCardId Int
  brand      String
  value      String
  coinsSpent Int
  giftCode   String
  redeemedAt DateTime @default(now())
}

model UniversityBenefit {
  id             String          @id @default(cuid())
  university     String
  title          String
  description    String
  savings        String
  howToClaim     String
  category       String
  isActive       Boolean         @default(true)
  isAiDiscovered Boolean         @default(false)
  communityAdded Boolean         @default(false)
  addedByUserId  String?
  upvotes        Int             @default(0)
  lastRefreshed  DateTime?
  sourceUrl      String?
  createdAt      DateTime        @default(now())
  benefitUpvotes BenefitUpvote[]
}

model BenefitUpvote {
  id        String            @id @default(cuid())
  benefitId String
  userId    String
  createdAt DateTime          @default(now())
  benefit   UniversityBenefit @relation(fields: [benefitId], references: [id])
  user      User              @relation(fields: [userId], references: [id])

  @@unique([benefitId, userId])
}

model UniversityDiscovery {
  id         String   @id @default(cuid())
  university String   @unique
  lastRunAt  DateTime @default(now())
}
