# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL — replace with your Railway/Neon/Supabase URL):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/stackd"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID → Application type: Web application
# 3. Add Authorized redirect URIs:
#      http://localhost:3001/auth/google/callback         (local dev)
#      https://YOUR_PRODUCTION_URL/auth/google/callback   (production)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a fresh secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_this_to_a_random_secret

# ── API URL ───────────────────────────────────────────────────────────────────
# Set this to your deployed backend URL in production.
# Leave commented out for local development (defaults to http://localhost:3001).
# API_URL=https://your-production-url.com
