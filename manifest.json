{
  "manifest_version": 3,
  "name": "Stackd",
  "version": "1.2.0",
  "description": "Share referral codes, earn coins, and redeem gift cards — built for students.",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "host_permissions": [
    "http://localhost:3001/*",
    "https://*/*"
  ]
}
