{
  "manifest_version": 3,
  "name": "Stackd",
  "version": "1.1.0",
  "description": "Share referral codes, earn coins, and redeem gift cards — built for students.",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": [
    "http://localhost:3001/*",
    "https://*/*"
  ]
}
